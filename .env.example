# YURI-BIAGINI — Environment Variables
# Copy to .env.local and fill values

# EGI API
NEXT_PUBLIC_EGI_API_URL=https://art.florenceegi.com/api
NEXT_PUBLIC_ARTIST_ID=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Contact Form
RESEND_API_KEY=
CONTACT_EMAIL_TO=yuri@florenceegi.com

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://yuri-biagini.florenceegi.com
NEXT_PUBLIC_SITE_NAME=Yuri Biagini

# Analytics
NEXT_PUBLIC_FE_ANALYTICS_SITE_ID=yuri-biagini
NEXT_PUBLIC_FE_ANALYTICS_ENDPOINT=https://hub.florenceegi.com/api/analytics/collect
